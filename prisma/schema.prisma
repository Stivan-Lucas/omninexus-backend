generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- TABELA DE EMPRESAS ---
model Company {
  id        Int      @id @default(autoincrement()) // ID Interno (Performance)
  publicId  String   @unique @default(uuid())      // ID Externo (Segurança)
  name      String   @unique
  active    Boolean  @default(true)

  // Auditoria
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sectors   Sector[]

  @@map("companies")
}

// --- TABELA DE SETORES ---
model Sector {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid())
  name      String

  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])

  // Auditoria
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  computers Computer[]

  @@map("sectors")
}

// --- TABELA DE COMPUTADORES (Inventário) ---
model Computer {
  id           Int      @id @default(autoincrement())
  publicId     String   @unique @default(uuid())

  hwUuid       String   @unique // O UUID que vem do Rust (Hardware ID)
  serialNumber String?
  hostname     String

  sectorId     Int
  sector       Sector   @relation(fields: [sectorId], references: [id])

  // Auditoria
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  telemetries Telemetry[]

  @@map("computers")
}

// --- TABELA DE TELEMETRIA (Logs Históricos) ---
model Telemetry {
  id               BigInt   @id @default(autoincrement()) // Telemetria cresce muito, use BigInt

  computerId       Int
  computer         Computer @relation(fields: [computerId], references: [id])

  // Dados do Sistema
  osName           String
  osVersion        String
  uptimeSeconds    Int

  // CPU
  cpuModel         String
  cpuGlobalUsage   Float
  cpuCores         Json

  // Memória
  totalRamKb       BigInt
  usedRamKb        BigInt
  ramUsagePercent  Float

  // JSONs complexos
  gpus             Json
  disks            Json
  networks         Json

  // Auditoria (Imutável)
  createdAt DateTime @default(now())

  @@index([computerId])
  @@index([createdAt])
  @@map("telemetries")
}
