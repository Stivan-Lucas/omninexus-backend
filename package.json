{
	"name": "backend",
	"module": "index.ts",
	"description": "Servidor de envios de comandos para o agente instalado na máquina do usuário",
	"type": "module",
	"private": true,
	"license": "Apache-2.0",
	"scripts": {
		"dev": "bun --watch src/server.ts",
		"start": "bun src/server.ts",
		"build": "bun build src/server.ts --outdir dist --target bun",
		"prepare": "husky",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check .",
		"release": "semantic-release",
		"version": "bun run build",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"generate": "prisma generate"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@types/bun": "latest",
		"@types/node": "^25.3.2",
		"husky": "^9.1.7",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.4.2",
		"semantic-release": "^25.0.3"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@prisma/client": "^7.4.2",
		"fastify": "^5.7.4",
		"pino-roll": "^4.0.0",
		"zod": "^4.3.6"
	}
}
