{
  "name": "omninexus_backend",
  "displayName": "🛡️ OmniNexus Ecosystem - Next-Gen RMM",
  "description": "O Omninexus Backend é o motor de processamento de telemetria do ecossistema Omninexus. Ele foi projetado para ser ultra-rápido, utilizando o runtime Bun e o framework Fastify para receber, validar e persistir os dados enviados pelo Omninexus Agent.",
  "module": "src/server.ts",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/Stivan-Lucas/backend#readme",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "https://apache.org/licenses/LICENSE-2.0"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Stivan-Lucas/backend.git"
  },
  "keywords": [
    "Bun",
    "Kafka",
    "Fastify",
    "OmniNexus",
    "REST"
  ],
  "author": {
    "email": "suporte@omninexus.com.br",
    "name": "Lucas Camargo Stivan",
    "url": "https://www.omninexus.com.br/"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/Stivan-Lucas/backend/issues",
    "email": "suporte@omninexus.com.br"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "ci": "biome check .",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "semantic-release": "^25.0.3"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.49.5",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "pino-roll": "^4.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
